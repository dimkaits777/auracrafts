---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string; // e.g. '/graphics'
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function pageUrl(page: number): string {
  return page === 1 ? `${baseUrl}/` : `${baseUrl}/${page}`;
}

function getVisiblePages(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

  const pages: (number | '...')[] = [1];

  if (current > 3) pages.push('...');

  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }

  if (current < total - 2) pages.push('...');

  pages.push(total);
  return pages;
}

const visiblePages = getVisiblePages(currentPage, totalPages);
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

<nav aria-label="Pagination" class="flex items-center justify-center gap-1 flex-wrap">
  <a
    href={hasPrev ? pageUrl(currentPage - 1) : undefined}
    aria-disabled={!hasPrev}
    class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors min-w-[44px] text-center ${
      hasPrev
        ? 'text-gray-700 hover:bg-gray-100'
        : 'text-gray-300 pointer-events-none'
    }`}
  >
    &larr; Prev
  </a>

  {
    visiblePages.map((p) =>
      p === '...' ? (
        <span class="px-2 py-2 text-sm text-gray-400 select-none">&hellip;</span>
      ) : (
        <a
          href={pageUrl(p)}
          aria-current={p === currentPage ? 'page' : undefined}
          class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors min-w-[44px] text-center ${
            p === currentPage
              ? 'bg-rose-600 text-white'
              : 'text-gray-700 hover:bg-gray-100'
          }`}
        >
          {p}
        </a>
      )
    )
  }

  <a
    href={hasNext ? pageUrl(currentPage + 1) : undefined}
    aria-disabled={!hasNext}
    class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors min-w-[44px] text-center ${
      hasNext
        ? 'text-gray-700 hover:bg-gray-100'
        : 'text-gray-300 pointer-events-none'
    }`}
  >
    Next &rarr;
  </a>
</nav>
