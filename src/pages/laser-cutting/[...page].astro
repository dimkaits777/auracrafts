---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Pagination from '../../components/Pagination.astro';
import type { Product } from '../../types/index';
import productsRaw from '../../data/productsLaser.json';

const ITEMS_PER_PAGE = 48;

export function getStaticPaths() {
  const products = productsRaw as Product[];
  const totalPages = Math.ceil(products.length / 48);

  return [
    { params: { page: undefined }, props: { currentPage: 1, totalPages } },
    ...Array.from({ length: totalPages - 1 }, (_, i) => ({
      params: { page: String(i + 2) },
      props: { currentPage: i + 2, totalPages },
    })),
  ];
}

const products = productsRaw as Product[];
const { currentPage, totalPages } = Astro.props;

const start = (currentPage - 1) * ITEMS_PER_PAGE;
const pageProducts = products.slice(start, start + ITEMS_PER_PAGE);
---

<BaseLayout
  title={`Laser Cutting Files${currentPage > 1 ? ` — Page ${currentPage}` : ''}`}
  description="SVG and DXF files for laser cutting and CNC — plaques, frames, and wooden Mother's Day gift designs. Download instantly."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Laser Cutting Files</h1>
      <p class="text-gray-500 mt-2">
        {products.length.toLocaleString()} designs for Mother's Day &mdash; page {currentPage} of {totalPages}
      </p>
    </div>

    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/laser-cutting" />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-8">
      {pageProducts.map((product) => <ProductCard product={product} />)}
    </div>

    <div class="mt-10">
      <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/laser-cutting" />
    </div>
  </div>
</BaseLayout>
