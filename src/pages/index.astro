---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    href: '/embroidery',
    label: 'Embroidery',
    description: "Machine embroidery designs for Mother\u2019s Day \u2014 flowers, quotes, and heartfelt patterns.",
    count: 1682,
    color: 'rose',
    icon: '🧵',
  },
  {
    href: '/laser-cutting',
    label: 'Laser Cutting',
    description: 'SVG files for CNC and laser cutting — plaques, frames, and wooden gift designs.',
    count: 1938,
    color: 'amber',
    icon: '✂️',
  },
  {
    href: '/graphics',
    label: 'Graphics',
    description: 'Clipart bundles, SVG vectors, and digital art perfect for cards, prints, and crafts.',
    count: 6111,
    color: 'violet',
    icon: '🎨',
  },
];
---

<BaseLayout title="Mother's Day Gifts" description="Find the perfect Mother's Day gift — embroidery patterns, laser cutting files, and graphics from Creative Fabrica.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-rose-50 via-white to-pink-50 py-20 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-rose-600 font-semibold text-sm uppercase tracking-widest mb-4">Mother's Day 2026</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-6">
        Gifts She'll Love,<br />Crafted with Heart
      </h1>
      <p class="text-lg text-gray-600 max-w-xl mx-auto">
        Thousands of embroidery patterns, laser cutting files, and graphics — download instantly and create something beautiful.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Browse by Category</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {
        categories.map(({ href, label, description, count, icon }) => (
          <a
            href={href}
            class="group flex flex-col gap-4 rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-md p-6 transition-shadow duration-200"
          >
            <div class="text-4xl">{icon}</div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-rose-600 transition-colors">
                {label}
              </h3>
              <p class="text-sm text-gray-500 mt-1 leading-relaxed">{description}</p>
            </div>
            <p class="mt-auto text-xs font-semibold text-rose-600 uppercase tracking-wide">
              {count.toLocaleString()} designs &rarr;
            </p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
